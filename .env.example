# Copy this file to .env and fill in your values
# DO NOT commit your actual .env file

FLASK_APP=run.py
FLASK_ENV=production

# Generate a strong secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-very-secret-key-here

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/smart_water_db?retryWrites=true&w=majority
